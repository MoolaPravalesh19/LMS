<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <link rel="stylesheet" href="/style6.css">
</head>
<body>
    <table>
        <tr>
            <th id="libraryid">Library ID</th>
            <th class="studentname">Student Name</th>
            <th class="bookid">Book ID</th>
            <th class="issuebook">Issued Book</th>
            <th class="issuedate">Issue Date</th>
            <th class="returndate">Return Date</th>
            <th class="accept">Accept</th>
            <th class="reject">Reject</th>
        </tr>
        <% for(user of user){ %>
            <tr>
                <td class="column1">
                    <%= user.libraryid %>
                </td>
                <td class="column1">
                    <%= user.studentname %>
                </td>
                <td class="column1">
                    <%= user.branch %>
                </td>
                <td class="column1">
                    <%= user.bookid %>
                </td>
                <td class="column2">
                    <%= user.issuebook %>
                </td>
                <td class="column3">
                    <%= user.issuedate %>
                </td>
                <td class="column4">
                    <%= user.returndate %>
                </td>
                <td class="column6">
                    <form method="post" action="/Dashboard/<%=user.bookid%>/<%=user.libraryid%>/accept">
                        <button>Accept</button>
                    </form>
                </td>
                <td class="column7">
                    <form method="post" action="/Dashboard/<%=user.bookid%>/<%=user.libraryid%>/reject">
                        <button>Reject</button>
                    </form>
                </td>
            </tr>
        <% } %>
    </table>
</body>
</html>