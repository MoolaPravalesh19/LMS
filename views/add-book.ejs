<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Add Book</title>
    <link rel="stylesheet" href="/style2.css">
</head>
<body>
    <div class="container">
        <h1>ADD BOOK</h1>
        <form method="post" action="/Admin/Dashboard/Add-book">
            <div class="input1">
                <label>BOOK ID</label>
                <input type="text" placeholder="Enter a book ID" name="bookid" class="bookid">
            </div>
            <div class="input2">
                <label>BOOK NAME</label>
                <input type="text" placeholder="Enter Book Name" name="bookname" class="bookname">
            </div>
            <div class="input3">
                <label>PUBLISHER NAME</label>
                <input type="text" placeholder="Enter publisher name" name="publishername" class="publishername">
            </div>
            <button class="btn right">ADD</button>
        </form>
    </div>
</body>
</html>