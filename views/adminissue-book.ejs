<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>student Issued Books Data</title>
    <link rel="stylesheet" href="/style4.css">
</head>
<body>
    <h1>ISSUED BOOKS</h1>
    <table>
        <tr>
            <th class="bookid">Library ID</th>
            <th class="bookid">Student Name</th>
            <th class="bookid">Branch</th>
            <th class="bookid">Book ID</th>
            <th class="issuebook">Issued Book</th>
            <th class="issuedate">Issue Date</th>
            <th class="returndate">Return Date</th>
        </tr>
        <% for(user of user){ %>
            <tr>
                <td class="column1">
                    <%= user.libraryid %>
                </td>
                <td class="column1">
                    <%= user.studentname %>
                </td>
                <td class="column1">
                    <%= user.branch %>
                </td>
                <td class="column1">
                    <%= user.bookid %>
                </td>
                <td class="column2">
                    <%= user.issuebook %>
                </td>
                <td class="column3">
                    <%= user.issuedate %>
                </td>
                <td class="column4">
                    <%= user.returndate %>
                </td>
            </tr>
        <% } %>
    </table>
</body>
</html>