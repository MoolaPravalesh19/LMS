<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Dashboard</title>
    <link rel="stylesheet" href="/style3.css">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.6.0/css/all.min.css"
        integrity="sha512-Kc323vGBEqzTmouAECnVceyQqyqdsSiqLQISBL29aUW4U/M7pSPA/gEUZQqv1cwx4OnYxTxve5UMg5GT6L4JJg=="
        crossorigin="anonymous" referrerpolicy="no-referrer" />
</head>
<body>
     <div class="top">
        <img src="https://thumbs.dreamstime.com/z/books-logo-illustrated-isolated-design-53710670.jpg" alt="">
        <h1>LIBRARY MANAGEMENT SYSTEM</h1>
        <h2>Dashboard</h2>
        
     </div>
     <div class="section">
        <div class="menu">
            <ul>
                <a href="http://localhost:3000/Library/Dashboard/Books"><li>Book List</li></a>
                <a href="http://localhost:3000/Dashboard/<%=studentinfo.libraryid %>/issued-books"><li>Issued book</li></a>
                <a href="http://localhost:3000/Dashboard/<%=studentinfo.libraryid %>/Returned-books"><li>Returned book</li></a>
                <a href="http://localhost:3000/Dashboard/<%= studentinfo.libraryid %>/issuebook"><li>Issue book</li></a>
                <a href="http://localhost:3000/Library/Dashboard/<%= studentinfo.libraryid %>/Accepted-requests"><li>Accepted Requests</li></a>
                <a href="http://localhost:3000/Library/Dashboard/<%= studentinfo.libraryid %>/Rejected-requests"><li>Rejected Request</li></a>
                <a href="http://localhost:3000/Library/Dashboard/Logout"><li>Logout</li></a>

            </ul>
         </div>
         <div class="main">
            <h2 class="student">Student Satistics</h2>
                <div class="boxes">
                    <div class="box1">
                        <h1><%= countissue %></h2>
                        <h2>Issued Books</h3>
                    </div>
                    <div class="box2">
                        <h1><%= countbook %></h1>
                        <h2>Available Books</h2>
                    </div>
                    <div class="box3">
                        <h1><%= countreturn  %></h1>
                        <h2>Returned Books</h2>
                    </div>
                    <div class="box4">
                        <h1><%= countaccept  %></h1>
                        <h2>Accept</h2>
                    </div>
                    <div class="box6">
                        <h1><%= countreject  %></h1>
                        <h2>Reject</h2>
                    </div>
                </div>
            <div class="profile">
                <h1>Student Info</h2>
                <div class="container">
                    <h2>Library ID : <%= studentinfo.libraryid %></h2>
                    <h2>Student Name: <%= studentinfo.studentname %></h2>
                    <h2>Branch : <%= studentinfo.branch  %></h2>
                    <H2>Email : <%= studentinfo.email %></H2>
                    <h2>Password : <%= studentinfo.password %></h3>
                </div>
            </div>
         </div>
     </div>

</body>
</html>