<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>ISSUE BOOK</title>
    <link rel="stylesheet" href="/style8.css">
  </head>
  <body>
    <h1>ISSUE BOOK</h1>
    <div class="form">
      <form method="post" action="/Dashboard/issue-book">
        <div class="libraryid">
            <label>Library ID :</label>
            <input type="text" name="libraryid" id="libraryid" placeholder="Enter your Library ID">
        </div>
        <div class="studentname">
            <label for="">Student Name:</label>
            <input type="text" id="studentname" name="studentname" placeholder="Enter your name">
        </div>
        <div class="branch-part">
          <Label>Branch :</Label>
          <select name="branch" id="branch">
            <option value="Information Technology">
              Information Technology
            </option>
            <option value="Computer Science And Engineering">
              Computer Science and Engineering
            </option>
            <option value="Mechanical Engineering">
              Mechanical Engineering
            </option>
            <option value="Civil Engineering">Civil Engineering</option>
            <option value="Electronics And Communication Engineering">
              Electronics and Communication Engineering
            </option>
          </select>
        </div>
        <div class="bookid">
            <label>Book ID :</label>
            <input type="text" id="bookid" placeholder="Enter Book ID" name="bookid">
          </div>
        <div class="bookname">
          <label>Book Name :</label>
          <input type="text" name="bookname" id="bookname" placeholder="Enter Book Name">
        </div>
        <div class="issuedate">
          <label>Issue Date :</label>
          <input type="date" id="issuedate" name="issuedate" id="">
        </div>
        <div class="returndate">
          <label>Return Date :</label>
          <input type="date" id="returndate" name="returndate" id="returndate">
        </div>
        <div class="button">
          <button class="btn">REQUEST</button>
        </div>
      </form>
    </div>
  </body>
</html>
