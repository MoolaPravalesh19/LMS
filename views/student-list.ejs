<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Student List</title>
    <link rel="stylesheet" href="/style4.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
<link href="https://fonts.googleapis.com/css2?family=Open+Sans:ital,wght@0,300..800;1,300..800&family=Playwrite+GB+S:ital,wght@0,100..400;1,100..400&display=swap" rel="stylesheet">
</head>
<body>
    <h1>Books Available</h1>
    <table>
        <tr>
            <th class="studentid">LIBRARY ID</th>
            <th class="studentname">STUDENT NAME</th>
            <th class="branch">BRANCH</th>
            <th class="email">EMAIL</th>
            <th class="password">PASSWORD</th>
        </tr>
        <% for(user of result){ %>
            <tr>
                <td class="column1">
                    <%= user.libraryid %>
                </td>
                <td class="column2">
                    <%= user.studentname %>
                </td>
                <td class="column3">
                    <%= user.branch %>
                </td>
                <td class="column1">
                    <%= user.email %>
                </td>
                <td class="column1">
                    <%= user.password %>
                </td>
            </tr>
        <% } %>
    </table>
</body>
</html>